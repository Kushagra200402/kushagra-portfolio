# Copy this file to .env.local and fill in your own values.

# Formspree form ID for the contact form (get one free at https://formspree.io)
# Example: if your endpoint is https://formspree.io/f/abcdwxyz, the ID is "abcdwxyz"
NEXT_PUBLIC_FORMSPREE_ID=

# Google Analytics Measurement ID (optional) — e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
